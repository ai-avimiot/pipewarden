# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.env
.venv
env/
venv/
ENV/

# Node.js (native-proxy action build tooling)
node_modules/
# The bundled action output is committed (GitHub runs it directly), so re-include
# it despite the generic dist/ rule above.
!native-proxy/action/dist/
!native-proxy/action/dist/**

# IDE
.idea/
.vscode/
*.swp
*.swo

